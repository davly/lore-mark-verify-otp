%% rebar.config -- lore-mark-verify Erlang/OTP SDK port.
%%
%% Cohort-canonical regulator-grade L43 Mirror-Mark v1 cold-verifier.
%% Algorithm-byte-identical to the Go canonical at
%% github.com/davly/lore-mark-verify. Zero Hex dependencies; OTP stdlib
%% only (`crypto`, `base64`, `binary`). Compatible with OTP 25.1+ (older
%% OTPs lack `crypto:hash_equals/2`; a manual XOR-fold fallback covers
%% OTP < 25.1).
%%
%% Build:    `rebar3 compile`
%% Tests:    `rebar3 ct` + `rebar3 proper` (PropEr properties)
%% Dialyzer: `rebar3 dialyzer`
%%
%% Discipline notes:
%%   - `deps` MUST stay empty (R145.B sibling-not-stacked). Adding any
%%     Hex dep pulls a transitive trust boundary and breaks the
%%     "regulator can re-derive with only OTP" cohort property.
%%   - `proper` is a TEST-only dep; the runtime is `deps = []`.
%%   - `erl_opts` adds `debug_info` so dialyzer + ct can pull source.

{erl_opts, [
    debug_info,
    warn_unused_vars,
    warn_shadow_vars,
    warn_unused_import,
    warn_obsolete_guard,
    warnings_as_errors
]}.

{deps, []}.

{ct_opts, [{enable_builtin_hooks, false}]}.

{cover_enabled, true}.
{cover_opts, [verbose]}.

{dialyzer, [
    {warnings, [
        no_return,
        no_unused,
        no_improper_lists,
        no_fun_app,
        no_match,
        no_opaque,
        no_fail_call,
        no_contracts,
        no_behaviours,
        no_undefined_callbacks,
        unmatched_returns,
        error_handling,
        underspecs
    ]}
]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls,
    deprecated_functions
]}.

{profiles, [
    {test, [
        {deps, [{proper, "1.4.0"}]},
        {erl_opts, [nowarn_export_all, {d, 'TEST'}]}
    ]}
]}.
