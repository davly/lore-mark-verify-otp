%% lore_mark_verify.app.src -- OTP application descriptor.
%%
%% LIBRARY application (no supervisor tree, no start/stop callback).
%% Consumers depend on this app and call the modules directly.
%%
%% Cohort-canonical regulator-grade L43 Mirror-Mark v1 cold-verifier.
%% Algorithm-byte-identical to github.com/davly/lore-mark-verify (Go).

{application, lore_mark_verify, [
