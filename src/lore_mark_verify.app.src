    {vsn, "0.1.0"},
    {registered, []},
    {applications, [
        kernel,
        stdlib,
        crypto
    ]},
    {modules, [
        lore_mark_verify
    ]},
    {licenses, ["Apache-2.0"]},
    {links, [{"GitHub", "https://github.com/davly/lore-mark-verify-otp"}]},
    {env, []}
]}.
